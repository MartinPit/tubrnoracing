# web/directus/example.env
# RENAME THIS TO .env BEFORE RUNNING DOCKER-COMPOSE
# ------------------------------------------------
# Replace all placeholder values with strong secrets.

# Database Credentials
DB_NAME="brnoracing_db"
DB_USER="directus_user"
DB_PASSWORD="<REPLACE_WITH_YOUR_DB_PASSWORD>"

# Directus Security Keys
AUTH_KEY="<REPLACE_WITH_AUTH_KEY>"
AUTH_SECRET="<REPLACE_WITH_AUTH_SECRET>"